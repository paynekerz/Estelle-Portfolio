---
import BaseLayout from '../layouts/BaseLayout.astro';
import GrainOverlay from '../components/ui/GrainOverlay.astro';
import Nav from '../components/ui/Nav.astro';
import Hero from '../components/ui/Hero.astro';
import StatsStrip from '../components/ui/StatsStrip.astro';
import Marquee from '../components/ui/Marquee.astro';
import About from '../components/ui/About.astro';
import Work from '../components/ui/Work.astro';
import Testimonials from '../components/ui/Testimonials.astro';
import Philosophy from '../components/ui/Philosophy.astro';
import Contact from '../components/ui/Contact.astro';
import Footer from '../components/ui/Footer.astro';
---

<BaseLayout>
  <GrainOverlay />
  <Nav />
  <main>
    <Hero />
    <StatsStrip />
    <Marquee />
    <About />
    <Work />
    <Testimonials />
    <Philosophy />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
