---
import { about } from '../../data/site';
---

<section id="about" class="about-section">
  <div class="about-left">
    <p class="eyebrow reveal">{about.eyebrow}</p>
    <h2 class="about-heading heading-accent reveal delay-1">
      {about.headline.before} <em>{about.headline.em}</em>
    </h2>
    <div class="about-body">
      {about.body.map((para, i) => (
        <p class={`about-para reveal delay-${i + 2}`}>{para}</p>
      ))}
      <p class="about-note reveal delay-4">{about.personalNote}</p>
    </div>
  </div>

  <div class="about-right">
    <div class="about-pillars reveal delay-1">
      <p class="about-section-label">{about.pillarsHeading}</p>
      {about.pillars.map((pillar) => (
        <div class="about-pillar hover-indent">
          <div>
            <p class="pillar-title">{pillar.title}</p>
          </div>
          <div>
            <p class="pillar-body">{pillar.body}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="about-skills reveal delay-2">
      <p class="about-section-label">{about.skillsHeading}</p>
      <div class="skills-grid">
        {about.skills.map((skill) => (
          <span class="skill-chip">{skill}</span>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8rem;
    padding: 7rem 3.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .about-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2-about);
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    margin-bottom: 2.5rem;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-para {
    font-size: 0.97rem;
    font-weight: 300;
    line-height: 1.85;
    color: var(--color-ink-2);
  }

  .about-note {
    font-size: 0.88rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-ink-3);
    margin-top: 0.5rem;
  }

  .about-section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-amber);
    margin-bottom: 2rem;
  }

  .about-pillars {
    border-top: 1px solid var(--color-border);
    margin-bottom: 3.5rem;
  }

  .about-pillar {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .pillar-title {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .pillar-body {
    font-size: 0.85rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-ink-2);
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  @media (max-width: 900px) {
    .about-section {
      grid-template-columns: 1fr;
      gap: 4rem;
      padding: 5rem 1.5rem;
    }
  }
</style>
